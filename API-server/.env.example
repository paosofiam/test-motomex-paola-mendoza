# Copiar a .env y ajustar valores. NO commitear .env (esta excluido en .gitignore).

# Conexion a MySQL de XAMPP (default: usuario root sin password en localhost:3306)
DATABASE_URL=mysql+pymysql://root:@localhost:3306/motomex

# Metadata de la app (se usa como title de FastAPI/Swagger)
APP_NAME=Motomex API
