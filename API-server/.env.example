# Copiar a .env y ajustar valores. NO commitear .env (esta excluido en .gitignore).

# Conexion a MySQL de XAMPP (default: usuario root sin password en localhost:3306)
DATABASE_URL=mysql+pymysql://root:@localhost:3306/motomex

# Metadata de la app (se usa como title de FastAPI/Swagger)
APP_NAME=Motomex API

# --- Solo para PRUEBAS (no se carga desde .env; se exporta en el entorno) ---
# Las pruebas leen TEST_DATABASE_URL del ENTORNO, no de este archivo. Apunta a una BD
# DEDICADA `motomex_test` (utf8mb4_unicode_ci), nunca a `motomex`. Ajusta puerto/credenciales
# a tu XAMPP (este proyecto usa el puerto 3307). PowerShell:
#   $env:TEST_DATABASE_URL = "mysql+pymysql://root:@127.0.0.1:3307/motomex_test"
# Si no se exporta, el conftest cae a SQLite en memoria (menor fidelidad).
